{
  "name": "phronesis",
  "version": "0.1.0",
  "description": "Hermes-inspired CLI wrapper for OpenCode + Phronesis plugins",
  "type": "module",
  "bin": {
    "phronesis": "./bin/phronesis.js"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "dependencies": {
    "js-yaml": "^4.1.0",
    "yargs": "^17.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luluthehungrycat/phronesis.git"
  },
  "homepage": "https://github.com/luluthehungrycat/phronesis#readme",
  "bugs": {
    "url": "https://github.com/luluthehungrycat/phronesis/issues"
  },
  "keywords": [
    "opencode",
    "cli",
    "developer-tools",
    "ai",
    "agent"
  ],
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "node tests/test.mjs && echo 'Tests passed. Ready to publish.'",
    "test": "node tests/test.mjs",
    "test:all": "node tests/test.mjs && node ../tests/plugins/test.mjs",
    "test:container": "cd .. && npm test",
    "version": "node -e \"const fs=require('fs'); const p=JSON.parse(fs.readFileSync('package.json','utf8')); const c=fs.readFileSync('../CHANGELOG.md','utf8'); console.log('v'+p.version);\"",
    "postversion": "git add ../CHANGELOG.md && git tag -a v$(node -e \"console.log(require('./package.json').version)\") -m \"chore: release v$(node -e \"console.log(require('./package.json').version)\")\""
  }
}
